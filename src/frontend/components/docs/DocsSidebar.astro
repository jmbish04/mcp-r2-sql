---
/**
 * DocsSidebar — SSR navigation for the docs site. Renders the category → page
 * tree with the active page highlighted. Independent of the main app nav.
 */
import { DOC_TREE } from "@/lib/docs";

interface Props {
  activeSlug: string;
}
const { activeSlug } = Astro.props;
---

<nav aria-label="Docs navigation" class="flex flex-col gap-6 p-5 text-sm">
  {
    DOC_TREE.map(({ category, pages }) => (
      <div class="flex flex-col gap-1">
        <p class="px-2 text-xs font-semibold uppercase tracking-wide text-muted-foreground">
          {category.label}
        </p>
        <ul class="flex flex-col gap-0.5">
          {pages.map((page) => {
            const active = page.slug === activeSlug;
            return (
              <li>
                <a
                  href={`/docs/${page.slug}`}
                  title={page.summary}
                  aria-current={active ? "page" : undefined}
                  class={`block rounded-md px-2 py-1.5 transition-colors ${
                    active
                      ? "bg-accent/20 font-medium text-foreground ring-1 ring-border/40"
                      : "text-muted-foreground hover:bg-accent/10 hover:text-foreground"
                  }`}
                >
                  {page.title}
                </a>
              </li>
            );
          })}
        </ul>
      </div>
    ))
  }
</nav>
