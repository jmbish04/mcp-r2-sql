---
/**
 * Landing page — R2 SQL warehouse analytics dashboard.
 *
 * Thin Astro shell: BaseLayout chrome (shared header) + the
 * `<WarehouseDashboard>` island, which owns all live data fetching
 * (diagnostics rollup + R2 SQL aggregate queries + recharts panels).
 *
 * Replaced the template-routing landing page per .agent/rules/startup.md;
 * the shared header and the dynamic docs links (/openapi.json, /swagger,
 * /scalar) remain available through the navbar/footer.
 */
import BaseLayout from "@/layouts/BaseLayout.astro";
import { WarehouseDashboard } from "@/components/warehouse";
---

<BaseLayout
  title="R2 SQL Analytics"
  description="Live analytics over the cslb-master-licenses-sql R2 Data Catalog warehouse: SF DBI permits, inspections, contractors, and complaints."
>
  <main class="container mx-auto flex max-w-7xl flex-col gap-8 px-4 py-10">
    <header class="flex flex-col gap-2">
      <div class="flex items-center gap-3">
        <span class="text-4xl">🧊</span>
        <h1 class="text-3xl font-semibold tracking-tight">R2 SQL Warehouse</h1>
      </div>
      <p class="max-w-3xl text-base text-muted-foreground">
        Live view of the <code>cslb-master-licenses-sql</code> Iceberg warehouse (SF DBI permits,
        inspections, contractors, complaints) — every number on this page comes from R2 SQL or the
        diagnostics rollup. Explore further in the
        <a href="/workbench" class="underline underline-offset-4">Query Workbench</a> or vet a firm in the
        <a href="/vetting" class="underline underline-offset-4">Vetting Tool</a>.
      </p>
    </header>

    <WarehouseDashboard client:load />
  </main>
</BaseLayout>
