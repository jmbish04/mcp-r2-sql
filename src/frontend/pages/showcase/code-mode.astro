---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { Card, CardContent, CardHeader, CardTitle } from "@/components/ui/card";
import { Badge } from "@/components/ui/badge";
---

<BaseLayout title="Code Mode Canvas" description="Dynamic sandboxed edge isolates with assistant-ui">
  <div class="container mx-auto px-4 py-12 max-w-7xl">

    <!-- Header -->
    <section class="mb-12">
      <div class="flex items-center gap-3 mb-4">
        <span class="text-5xl">⚡</span>
        <div>
          <h1 class="text-4xl font-bold tracking-tight">Code Mode Canvas</h1>
          <p class="text-muted-foreground mt-2">Dynamic sandboxed edge isolates with DynamicWorkerExecutor</p>
        </div>
      </div>
    </section>

    <!-- Overview -->
    <section class="mb-12">
      <Card class="border-zinc-800 bg-zinc-950">
        <CardHeader>
          <CardTitle>Showcase Overview</CardTitle>
        </CardHeader>
        <CardContent class="space-y-4">
          <p class="text-sm text-muted-foreground">
            Code Mode Canvas demonstrates how to embed an interactive layout coupling <code class="text-orange-400">AssistantSidebar</code> alongside a custom layout block that maps out an <code class="text-orange-400">executePlan</code> generative UI container tool view.
          </p>
          <div class="flex flex-wrap gap-2">
            <Badge className="bg-orange-950 text-orange-400 border-orange-800">Dynamic Workers</Badge>
            <Badge className="bg-blue-950 text-blue-400 border-blue-800">V8 Isolates</Badge>
            <Badge className="bg-purple-950 text-purple-400 border-purple-800">Code Execution</Badge>
            <Badge className="bg-green-950 text-green-400 border-green-800">assistant-ui</Badge>
          </div>
        </CardContent>
      </Card>
    </section>

    <!-- Architecture Diagram -->
    <section class="mb-12">
      <h2 class="text-2xl font-bold mb-6">Architecture Flow</h2>
      <Card class="border-zinc-800 bg-zinc-950">
        <CardContent class="p-8">
          <div class="flex flex-col md:flex-row gap-4 items-center justify-between">
            <div class="flex-1 p-4 bg-blue-950/30 border border-blue-600 rounded-lg text-center">
              <p class="font-semibold text-blue-400">User Input</p>
              <p class="text-xs text-muted-foreground mt-1">Request via assistant-ui</p>
            </div>
            <span class="text-2xl text-muted-foreground">→</span>
            <div class="flex-1 p-4 bg-purple-950/30 border border-purple-600 rounded-lg text-center">
              <p class="font-semibold text-purple-400">Agent LLM</p>
              <p class="text-xs text-muted-foreground mt-1">Generates TypeScript plan</p>
            </div>
            <span class="text-2xl text-muted-foreground">→</span>
            <div class="flex-1 p-4 bg-orange-950/30 border border-orange-600 rounded-lg text-center">
              <p class="font-semibold text-orange-400">Dynamic Worker</p>
              <p class="text-xs text-muted-foreground mt-1">Executes in V8 isolate</p>
            </div>
            <span class="text-2xl text-muted-foreground">→</span>
            <div class="flex-1 p-4 bg-green-950/30 border border-green-600 rounded-lg text-center">
              <p class="font-semibold text-green-400">Result Stream</p>
              <p class="text-xs text-muted-foreground mt-1">Rendered in UI</p>
            </div>
          </div>
        </CardContent>
      </Card>
    </section>

    <!-- Implementation -->
    <section class="mb-12">
      <h2 class="text-2xl font-bold mb-6">Implementation Reference</h2>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <!-- Backend Implementation -->
        <Card class="border-zinc-800 bg-zinc-950">
          <CardHeader>
            <div class="flex items-center justify-between">
              <CardTitle class="text-base">Backend: CodeModeAgent.ts</CardTitle>
              <Badge variant="secondary">Agent SDK</Badge>
            </div>
          </CardHeader>
          <CardContent>
            <pre class="text-xs bg-zinc-900 p-4 rounded-lg border border-zinc-800 overflow-x-auto max-h-96"><code class="text-zinc-300">{`import { AIChatAgent } from "@cloudflare/ai-chat";
import { generateText } from "ai";
import { DynamicWorkerExecutor } from "@cloudflare/codemode";
import { z } from "zod";

export class CodeModeAgent extends AIChatAgent {
  async onStart() {
    // Initialize Dynamic Worker executor
    this.executor = new DynamicWorkerExecutor({
      loader: this.env.WORKER_LOADERS,
      timeout: 30000,
      globalOutbound: null // Block network access
    });
  }

  async onChatMessage(onFinish) {
    const result = await generateText({
      model: this.env.AI,
      prompt: this.messages[this.messages.length - 1].content,
      tools: {
        executePlan: {
          description: "Execute a generated TypeScript plan securely on Cloudflare.",
          parameters: z.object({
            code: z.string().describe("TypeScript code to execute")
          }),
          execute: async ({ code }) => {
            // Load code into Dynamic Worker
            const runtime = await this.executor.load({
              code,
              compatibilityDate: "2026-05-25"
            });

            // Execute and return result
            const response = await runtime.fetch("/");
            const result = await response.text();

            return {
              status: "success",
              output: result,
              executionTime: Date.now()
            };
          }
        }
      }
    });

    return result;
  }
}`}</code></pre>
          </CardContent>
        </Card>

        <!-- Frontend Implementation -->
        <Card class="border-zinc-800 bg-zinc-950">
          <CardHeader>
            <div class="flex items-center justify-between">
              <CardTitle class="text-base">Frontend: CodeModeCanvas.tsx</CardTitle>
              <Badge variant="secondary">assistant-ui</Badge>
            </div>
          </CardHeader>
          <CardContent>
            <pre class="text-xs bg-zinc-900 p-4 rounded-lg border border-zinc-800 overflow-x-auto max-h-96"><code class="text-zinc-300">{`import { useAgent } from "agents/react";
import { useAgentChat } from "@cloudflare/ai-chat/react";
import { Thread, ToolFallback } from "@assistant-ui/react";

export function CodeModeCanvas() {
  const agent = useAgent({
    agent: "CodeModeAgent",
    name: "code-session"
  });

  const { messages, isStreaming } = useAgentChat({ agent });

  return (
    <div className="h-screen flex bg-zinc-950">
      {/* Sidebar with Chat Thread */}
      <div className="w-96 border-r border-zinc-800 flex flex-col">
        <div className="p-4 border-b border-zinc-800">
          <h2 className="font-bold text-lg">Code Mode Agent</h2>
          <p className="text-xs text-muted-foreground">
            Dynamic Worker execution
          </p>
        </div>

        <Thread runtime={agent} className="flex-1 overflow-auto">
          {/* Custom tool rendering for executePlan */}
          <ToolFallback
            toolName="executePlan"
            render={({ args, result }) => (
              <div className="p-4 bg-zinc-900 border border-zinc-800 rounded-lg m-4">
                <div className="flex items-center gap-2 mb-2">
                  <span className="text-orange-500 font-bold text-xs uppercase">
                    Code Canvas Sandbox
                  </span>
                  {isStreaming && (
                    <span className="text-xs text-muted-foreground">
                      Executing...
                    </span>
                  )}
                </div>

                {/* Code Display */}
                <pre className="bg-zinc-950 p-3 rounded text-xs overflow-auto max-h-48 text-zinc-300 border border-zinc-700">
                  <code>{args.code}</code>
                </pre>

                {/* Result Display */}
                {result && (
                  <div className="mt-4 p-3 bg-zinc-950 rounded border border-emerald-900">
                    <p className="text-xs font-semibold text-emerald-400 mb-1">
                      Output:
                    </p>
                    <pre className="text-xs text-emerald-300">
                      {JSON.stringify(result, null, 2)}
                    </pre>
                  </div>
                )}
              </div>
            )}
          />
        </Thread>
      </div>

      {/* Main Canvas Area */}
      <div className="flex-1 p-8 overflow-auto">
        <div className="max-w-4xl mx-auto">
          <h3 className="text-2xl font-bold mb-4">
            Dynamic Worker Code Execution
          </h3>
          <p className="text-muted-foreground mb-6">
            The agent can generate and execute TypeScript code
            in isolated V8 sandboxes with ~15ms cold start latency.
          </p>

          <div className="grid grid-cols-1 md:grid-cols-3 gap-4">
            <Card className="border-zinc-800 bg-zinc-900">
              <CardHeader>
                <CardTitle className="text-sm">Cold Start</CardTitle>
              </CardHeader>
              <CardContent>
                <p className="text-2xl font-bold text-orange-500">~15ms</p>
                <p className="text-xs text-muted-foreground">
                  V8 isolate initialization
                </p>
              </CardContent>
            </Card>

            <Card className="border-zinc-800 bg-zinc-900">
              <CardHeader>
                <CardTitle className="text-sm">Sandbox</CardTitle>
              </CardHeader>
              <CardContent>
                <p className="text-2xl font-bold text-blue-500">Zero-trust</p>
                <p className="text-xs text-muted-foreground">
                  No network or file access
                </p>
              </CardContent>
            </Card>

            <Card className="border-zinc-800 bg-zinc-900">
              <CardHeader>
                <CardTitle className="text-sm">Cost Savings</CardTitle>
              </CardHeader>
              <CardContent>
                <p className="text-2xl font-bold text-green-500">80%</p>
                <p className="text-xs text-muted-foreground">
                  Reduced inference tokens
                </p>
              </CardContent>
            </Card>
          </div>
        </div>
      </div>
    </div>
  );
}`}</code></pre>
          </CardContent>
        </Card>
      </div>
    </section>

    <!-- Configuration -->
    <section class="mb-12">
      <h2 class="text-2xl font-bold mb-6">Wrangler Configuration</h2>
      <Card class="border-zinc-800 bg-zinc-950">
        <CardContent class="p-6">
          <pre class="text-xs bg-zinc-900 p-4 rounded-lg border border-zinc-800 overflow-x-auto"><code class="text-zinc-300">{`{
  "name": "codemode-showcase",
  "main": "dist/_worker.js/index.js",
  "compatibility_date": "2026-05-25",
  "durable_objects": {
    "bindings": [
      {
        "name": "CODE_MODE_AGENT",
        "class_name": "CodeModeAgent"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["CodeModeAgent"]
    }
  ],
  "worker_loaders": [
    {
      "binding": "WORKER_LOADERS"
    }
  ],
  "ai": {
    "binding": "AI"
  }
}`}</code></pre>
        </CardContent>
      </Card>
    </section>

    <!-- Key Features -->
    <section class="mb-12">
      <h2 class="text-2xl font-bold mb-6">Key Features</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <Card class="border-zinc-800 bg-zinc-950">
          <CardHeader>
            <CardTitle class="text-base flex items-center gap-2">
              <span className="text-xl">🔒</span> Zero-Trust Execution
            </CardTitle>
          </CardHeader>
          <CardContent>
            <p class="text-sm text-muted-foreground">
              Dynamic Workers eliminate file system access and explicitly control outbound fetches. The <code class="text-orange-400">globalOutbound: null</code> setting blocks all network access from the sandbox.
            </p>
          </CardContent>
        </Card>

        <Card class="border-zinc-800 bg-zinc-950">
          <CardHeader>
            <CardTitle class="text-base flex items-center gap-2">
              <span className="text-xl">⚡</span> Millisecond Latency
            </CardTitle>
          </CardHeader>
          <CardContent>
            <p class="text-sm text-muted-foreground">
              V8 isolates start in ~15ms compared to 2-30 seconds for traditional containers. This enables real-time code execution for interactive agent workflows.
            </p>
          </CardContent>
        </Card>

        <Card class="border-zinc-800 bg-zinc-950">
          <CardHeader>
            <CardTitle class="text-base flex items-center gap-2">
              <span className="text-xl">💡</span> Token Optimization
            </CardTitle>
          </CardHeader>
          <CardContent>
            <p class="text-sm text-muted-foreground">
              Instead of making hundreds of sequential MCP tool calls, agents write a single TypeScript execution plan, reducing token context by up to 80%.
            </p>
          </CardContent>
        </Card>

        <Card class="border-zinc-800 bg-zinc-950">
          <CardHeader>
            <CardTitle class="text-base flex items-center gap-2">
              <span className="text-xl">🎨</span> Generative UI
            </CardTitle>
          </CardHeader>
          <CardContent>
            <p class="text-sm text-muted-foreground">
              The <code class="text-purple-400">ToolFallback</code> component from assistant-ui intercepts the <code class="text-purple-400">executePlan</code> tool call and renders custom React UI with code preview and execution results.
            </p>
          </CardContent>
        </Card>
      </div>
    </section>

    <!-- Use Cases -->
    <section>
      <h2 class="text-2xl font-bold mb-6">Real-World Use Cases</h2>
      <div class="space-y-4">
        <Card class="border-zinc-800 bg-zinc-950">
          <CardHeader>
            <CardTitle class="text-base">Data Processing Automation</CardTitle>
          </CardHeader>
          <CardContent>
            <p class="text-sm text-muted-foreground">
              Agent generates TypeScript to transform CSV data, execute calculations, and format results - all in a single execution instead of thousands of tool calls.
            </p>
          </CardContent>
        </Card>

        <Card class="border-zinc-800 bg-zinc-950">
          <CardHeader>
            <CardTitle class="text-base">API Integration Prototyping</CardTitle>
          </CardHeader>
          <CardContent>
            <p class="text-sm text-muted-foreground">
              Rapidly test and iterate on API integrations by having the agent write and execute fetch logic with custom headers, authentication, and response parsing.
            </p>
          </CardContent>
        </Card>

        <Card class="border-zinc-800 bg-zinc-950">
          <CardHeader>
            <CardTitle class="text-base">Custom Business Logic Execution</CardTitle>
          </CardHeader>
          <CardContent>
            <p class="text-sm text-muted-foreground">
              Generate and execute custom algorithms, pricing calculations, or data validation rules on-demand without deploying new code.
            </p>
          </CardContent>
        </Card>
      </div>
    </section>

  </div>
</BaseLayout>
