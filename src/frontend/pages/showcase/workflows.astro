---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { Card, CardContent, CardHeader, CardTitle } from "@/components/ui/card";
import { Badge } from "@/components/ui/badge";
---

<BaseLayout title="Workflows Pipeline" description="Real-time durable task progress tracking with Dynamic Workflows">
  <div class="container mx-auto px-4 py-12 max-w-7xl">

    <section class="mb-12">
      <div class="flex items-center gap-3 mb-4">
        <span class="text-5xl">⏱️</span>
        <div>
          <h1 class="text-4xl font-bold tracking-tight">Workflows Progress Pipeline</h1>
          <p class="text-muted-foreground mt-2">Real-time durable task updates with Dynamic Workflows</p>
        </div>
      </div>
    </section>

    <section class="mb-12">
      <Card class="border-zinc-800 bg-zinc-950">
        <CardHeader>
          <CardTitle>Showcase Overview</CardTitle>
        </CardHeader>
        <CardContent class="space-y-4">
          <p class="text-sm text-muted-foreground">
            Workflows Pipeline implements custom <code class="text-orange-400">MessagePartGrouping</code> tracking long-running progress states utilizing standard Shadcn <code class="text-orange-400">Progress</code> components syncing percent bars dynamically.
          </p>
          <div class="flex flex-wrap gap-2">
            <Badge className="bg-blue-950 text-blue-400 border-blue-800">Dynamic Workflows</Badge>
            <Badge className="bg-purple-950 text-purple-400 border-purple-800">Durable Execution</Badge>
            <Badge className="bg-green-950 text-green-400 border-green-800">Progress Tracking</Badge>
            <Badge className="bg-orange-950 text-orange-400 border-orange-800">Real-time Updates</Badge>
          </div>
        </CardContent>
      </Card>
    </section>

    <section class="mb-12">
      <h2 class="text-2xl font-bold mb-6">Implementation Reference</h2>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <Card class="border-zinc-800 bg-zinc-950">
          <CardHeader>
            <div class="flex items-center justify-between">
              <CardTitle class="text-base">Backend: LongTaskWorkflow.ts</CardTitle>
              <Badge variant="secondary">Workflows</Badge>
            </div>
          </CardHeader>
          <CardContent>
            <pre class="text-xs bg-zinc-900 p-4 rounded-lg border border-zinc-800 overflow-x-auto max-h-96"><code class="text-zinc-300">{`import { AIChatAgent } from "@cloudflare/ai-chat";
import { AgentWorkflow } from "cloudflare:workers";

export class TranscriptionWorkflow extends AgentWorkflow {
  async run(event, step) {
    const audioFile = event.payload;

    // Durable step 1: Audio transcription via Workers AI Whisper
    const transcription = await step.do("transcribe", async () => {
      await this.agent.reportProgress({
        step: "transcribing",
        percent: 25,
        message: "Transcribing audio with Whisper..."
      });

      const result = await this.env.AI.run("@cf/openai/whisper", {
        audio: audioFile
      });

      return result.text;
    });

    // Durable step 2: Semantic vector ingestion to Vectorize
    await step.do("vectorize", async () => {
      await this.agent.reportProgress({
        step: "vectorizing",
        percent: 75,
        message: "Creating semantic embeddings..."
      });

      // Generate embeddings
      const embeddings = await this.env.AI.run(
        "@cf/baai/bge-base-en-v1.5",
        { text: transcription }
      );

      // Store in Vectorize
      await this.env.VECTORIZE.insert([{
        id: event.id,
        values: embeddings.data[0],
        metadata: { source: "transcription" }
      }]);
    });

    // Final progress update
    await this.agent.reportProgress({
      step: "complete",
      percent: 100,
      message: "Transcription and indexing complete!"
    });

    return {
      transcription,
      status: "complete"
    };
  }
}

export class WorkflowsAgent extends AIChatAgent {
  async onChatMessage() {
    // Trigger workflow from agent
    const workflowId = await this.env.TRANSCRIPTION_WORKFLOW.start({
      payload: this.uploadedFile
    });

    return {
      workflowId,
      status: "started"
    };
  }
}`}</code></pre>
          </CardContent>
        </Card>

        <Card class="border-zinc-800 bg-zinc-950">
          <CardHeader>
            <div class="flex items-center justify-between">
              <CardTitle class="text-base">Frontend: TranscriptionBubble.tsx</CardTitle>
              <Badge variant="secondary">assistant-ui</Badge>
            </div>
          </CardHeader>
          <CardContent>
            <pre class="text-xs bg-zinc-900 p-4 rounded-lg border border-zinc-800 overflow-x-auto max-h-96"><code class="text-zinc-300">{`import { useAgent } from "agents/react";
import { useAgentChat } from "@cloudflare/ai-chat/react";
import { Progress } from "@/components/ui/progress";

export function WorkflowsInterface() {
  const agent = useAgent({
    agent: "WorkflowsAgent",
    name: "workflows-session"
  });

  const { messages } = useAgentChat({ agent });

  return (
    <div className="p-4">
      {messages.map((message) => (
        <WorkflowProgressBubble
          key={message.id}
          message={message}
        />
      ))}
    </div>
  );
}

function WorkflowProgressBubble({ message }) {
  // Extract progress metadata from message
  const metadata = message.metadata || {};
  const percent = metadata.percent || 0;
  const step = metadata.step || "queued";
  const statusMessage = metadata.message || "Processing...";

  return (
    <div className="p-4 bg-zinc-900 border border-zinc-800 rounded-lg mb-4">
      <div className="flex justify-between items-center mb-2">
        <span className="text-xs text-zinc-400 font-semibold uppercase">
          Whisper Transcription Pipeline
        </span>
        <span className="text-xs text-orange-500 font-bold">
          {percent}%
        </span>
      </div>

      {/* Progress Bar */}
      <Progress
        value={percent}
        className="h-2 bg-zinc-800"
      />

      {/* Status Message */}
      <div className="mt-3 flex items-center gap-2">
        {percent < 100 && (
          <div className="w-2 h-2 rounded-full bg-orange-500 animate-pulse" />
        )}
        {percent === 100 && (
          <div className="w-2 h-2 rounded-full bg-green-500" />
        )}
        <p className="text-zinc-400 text-xs italic">
          {statusMessage}
        </p>
      </div>

      {/* Step Indicator */}
      <div className="mt-3 flex gap-2">
        <div className={\`text-xs px-2 py-1 rounded \${
          step === "transcribing" || step === "complete"
            ? "bg-green-950 text-green-400 border border-green-800"
            : "bg-zinc-800 text-zinc-500"
        }\`}>
          Transcribe
        </div>
        <div className={\`text-xs px-2 py-1 rounded \${
          step === "vectorizing" || step === "complete"
            ? "bg-green-950 text-green-400 border border-green-800"
            : "bg-zinc-800 text-zinc-500"
        }\`}>
          Vectorize
        </div>
        <div className={\`text-xs px-2 py-1 rounded \${
          step === "complete"
            ? "bg-green-950 text-green-400 border border-green-800"
            : "bg-zinc-800 text-zinc-500"
        }\`}>
          Complete
        </div>
      </div>
    </div>
  );
}`}</code></pre>
          </CardContent>
        </Card>
      </div>
    </section>

    <section class="mb-12">
      <h2 class="text-2xl font-bold mb-6">Wrangler Configuration</h2>
      <Card class="border-zinc-800 bg-zinc-950">
        <CardContent class="p-6">
          <pre class="text-xs bg-zinc-900 p-4 rounded-lg border border-zinc-800 overflow-x-auto"><code class="text-zinc-300">{`{
  "name": "workflows-showcase",
  "main": "dist/_worker.js/index.js",
  "compatibility_date": "2026-05-25",
  "durable_objects": {
    "bindings": [
      {
        "name": "WORKFLOWS_AGENT",
        "class_name": "WorkflowsAgent"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["WorkflowsAgent"]
    }
  ],
  "workflows": [
    {
      "name": "TRANSCRIPTION_WORKFLOW",
      "class_name": "TranscriptionWorkflow"
    }
  ],
  "ai": {
    "binding": "AI"
  },
  "vectorize": {
    "bindings": [
      {
        "binding": "VECTORIZE",
        "index_name": "transcription_index"
      }
    ]
  }
}`}</code></pre>
        </CardContent>
      </Card>
    </section>

    <section class="mb-12">
      <h2 class="text-2xl font-bold mb-6">Key Features</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <Card class="border-zinc-800 bg-zinc-950">
          <CardHeader>
            <CardTitle class="text-base flex items-center gap-2">
              <span class="text-xl">🔄</span> Durable Execution
            </CardTitle>
          </CardHeader>
          <CardContent>
            <p class="text-sm text-muted-foreground">
              Workflows survive failures, network drops, and system reboots. Each step is durable and will retry automatically until successful.
            </p>
          </CardContent>
        </Card>

        <Card class="border-zinc-800 bg-zinc-950">
          <CardHeader>
            <CardTitle class="text-base flex items-center gap-2">
              <span class="text-xl">📊</span> Real-time Progress
            </CardTitle>
          </CardHeader>
          <CardContent>
            <p class="text-sm text-muted-foreground">
              Progress updates stream to the frontend via WebSocket, updating progress bars and status messages in real-time as the workflow executes.
            </p>
          </CardContent>
        </Card>

        <Card class="border-zinc-800 bg-zinc-950">
          <CardHeader>
            <CardTitle class="text-base flex items-center gap-2">
              <span class="text-xl">⏱️</span> Long-Running Tasks
            </CardTitle>
          </CardHeader>
          <CardContent>
            <p class="text-sm text-muted-foreground">
              Workflows can run for hours or days, making them ideal for batch processing, data migrations, or multi-step AI pipelines.
            </p>
          </CardContent>
        </Card>

        <Card class="border-zinc-800 bg-zinc-950">
          <CardHeader>
            <CardTitle class="text-base flex items-center gap-2">
              <span class="text-xl">🎨</span> Custom Progress UI
            </CardTitle>
          </CardHeader>
          <CardContent>
            <p class="text-sm text-muted-foreground">
              Shadcn Progress components combined with step indicators provide a polished, professional UI for tracking workflow execution.
            </p>
          </CardContent>
        </Card>
      </div>
    </section>

    <section>
      <h2 class="text-2xl font-bold mb-6">Real-World Use Cases</h2>
      <div class="space-y-4">
        <Card class="border-zinc-800 bg-zinc-950">
          <CardHeader>
            <CardTitle class="text-base">Audio/Video Processing</CardTitle>
          </CardHeader>
          <CardContent>
            <p class="text-sm text-muted-foreground">
              Transcribe hours of audio with Whisper, generate embeddings, index to Vectorize, and enable semantic search - all in a durable, resumable workflow.
            </p>
          </CardContent>
        </Card>

        <Card class="border-zinc-800 bg-zinc-950">
          <CardHeader>
            <CardTitle class="text-base">Data Migration Pipelines</CardTitle>
          </CardHeader>
          <CardContent>
            <p class="text-sm text-muted-foreground">
              Move millions of records between databases with progress tracking, automatic retries, and guaranteed completion even if the process takes days.
            </p>
          </CardContent>
        </Card>

        <Card class="border-zinc-800 bg-zinc-950">
          <CardHeader>
            <CardTitle class="text-base">Multi-Step AI Workflows</CardTitle>
          </CardHeader>
          <CardContent>
            <p class="text-sm text-muted-foreground">
              Chain multiple LLM calls, vector searches, and API integrations into a single durable workflow with progress visibility at each step.
            </p>
          </CardContent>
        </Card>
      </div>
    </section>

  </div>
</BaseLayout>
