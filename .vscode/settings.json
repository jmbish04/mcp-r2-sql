{
  "files.associations": {
    "*.css": "tailwindcss",
    // Agent definition files in the sync orchestration layer → Markdown
    "**/orchestration/sync/.github/agents/*.md": "markdown",
    "**/orchestration/sync/.github/agents/*.agent.md": "markdown",
    // Workflow templates in the sync orchestration layer → YAML
    "**/orchestration/sync/.github/workflows/*.yml": "yaml",
    "**/orchestration/sync/.github/workflows/*.yaml": "yaml",
    "wrangler.jsonc": "jsonc"
  },
  "yaml.schemas": {
    "https://json.schemastore.org/github-workflow.json": [
      ".github/workflows/*.yml",
      "**/orchestration/sync/.github/workflows/*.yml",
      "**/orchestration/sync/.github/workflows/*.yaml"
    ]
  },
  "[yaml]": {
    "editor.insertSpaces": true,
    "editor.tabSize": 2,
    "editor.autoIndent": "advanced"
  },
  "[markdown]": {
    "editor.wordWrap": "on",
    "editor.quickSuggestions": {
      "other": "off",
      "comments": "off",
      "strings": "off"
    }
  },
  "json.format.keepLines": true,
  "[jsonc]": {
    "editor.formatOnSave": false,
    "editor.defaultFormatter": "vscode.json-language-features"
  },
  "json.schemas": [
    {
      "fileMatch": ["**/*.jsonc", "wrangler.jsonc"],
      "schema": {
        "allowTrailingCommas": true
      }
    }
  ],
  "tailwindCSS.classFunctions": ["cva", "cn"],
  "css.validate": false,
  "less.validate": false,
  "scss.validate": false
}
