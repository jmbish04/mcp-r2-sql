{
  "name": "mcp-r2-sql",
  "version": "26.02.24",
  "description": "The template helps you build apps with Astro, Tailwind CSS, and shadcn/ui.",
  "license": "MIT",
  "author": {
    "name": "126colby",
    "url": "https://github.com/126colby"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jmbish04/mcp-r2-sql.git"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "wrangler dev -c dist/server/wrangler.json",
    "start": "astro dev",
    "fmt": "oxfmt",
    "lint": "oxlint",
    "check": "oxlint && oxfmt",
    "db:generate": "drizzle-kit generate",
    "migrate:local": "pnpm run db:generate && npx wrangler d1 migrations apply DB --local",
    "migrate:remote": "pnpm run db:generate && npx wrangler d1 migrations apply DB --remote",
    "deploy": "pnpm run build && pnpm run migrate:remote && npx wrangler deploy -c dist/server/wrangler.json",
    "deploy:preview": "pnpm run build && npx wrangler versions upload -c dist/server/wrangler.json",
    "cf-typegen": "wrangler types",
    "deps:lockfile": "corepack pnpm install --no-frozen-lockfile && wrangler types",
    "deps:update": "corepack pnpm update --latest && corepack pnpm install --no-frozen-lockfile && wrangler types"
  },
  "dependencies": {
    "@ai-sdk/react": "^3.0.204",
    "@assistant-ui/react": "^0.14.18",
    "@assistant-ui/react-ai-sdk": "^1.3.35",
    "@astrojs/cloudflare": "^13.7.0",
    "@astrojs/react": "^5.0.7",
    "@base-ui/react": "^1.5.0",
    "@cloudflare/ai-chat": "^0.8.4",
    "@cloudflare/workers-types": "^4.20260612.1",
    "@fontsource-variable/inter": "^5.2.8",
    "@hono/swagger-ui": "^0.6.1",
    "@hono/zod-openapi": "^1.4.0",
    "@hono/zod-validator": "^0.8.0",
    "@scalar/hono-api-reference": "^0.11.3",
    "@tailwindcss/vite": "^4.3.0",
    "agents": "^0.15.0",
    "ai": "^6.0.202",
    "astro": "^6.4.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "0.8.3",
    "hono": "^4.12.25",
    "leaflet": "^1.9.4",
    "leaflet.markercluster": "^1.5.3",
    "lucide-react": "^1.18.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "recharts": "3.8.1",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "workers-ai-provider": "^3.1.14",
    "zod": "^4.4.3",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.21",
    "@types/leaflet.markercluster": "^1.5.6",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "drizzle-kit": "^0.31.10",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0",
    "shadcn": "^4.11.0",
    "typescript": "^6.0.3",
    "wrangler": "^4.100.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@10.33.2"
}
